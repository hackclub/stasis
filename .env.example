DATABASE_URL="postgresql://postgres:postgres@localhost:5432/stasis?schema=public"

BETTER_AUTH_SECRET=GENERATE A RANDOM SECRET
BETTER_AUTH_URL=http://localhost:3000

HCA_CLIENT_ID=
HCA_CLIENT_SECRET=

HACKATIME_CLIENT_ID=
HACKATIME_CLIENT_SECRET=

AIRTABLE_API_KEY=
AIRTABLE_BASE_ID=
AIRTABLE_RSVP_TABLE_NAME=RSVPs

REQUIRE_BASICAUTH=false
BASICAUTH_USERNAME=
BASICAUTH_PASSWORD=

# Use cloudflare R2
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=
S3_ENDPOINT=
S3_PUBLIC_URL=

# Optional: Grant admin access to a specific user by email
SUPERADMIN_EMAIL=

# Slack Bot Token (for fetching profile pictures) (needs users:read scope)
SLACK_BOT_TOKEN=
# Set to "false" to disable inviting she/her users to #stasis-secret-spot
ENABLE_SECRET_SPOT_INVITE=

NODE_ENV=development

# Loops transactional email
LOOPS_API_KEY=
LOOPS_REFERRAL_TRANSACTIONAL_ID=

# Pre-launch mode - shows RSVP-only page when true
NEXT_PUBLIC_PRELAUNCH_MODE=false

# Skip YSWS eligibility verification check (for local development)
NEXT_PUBLIC_SKIP_YSWS_VERIFICATION_CHECK=false

# Save RSVPs to PostgreSQL instead of Airtable (use when Airtable is down)
RSVP_USE_POSTGRES=false

# Pull address & birthday PII from Hack Club Auth (requires PII_ENCRYPTION_KEY)
PULL_HCA_PII=
PII_ENCRYPTION_KEY=

# GitHub proxy API key for automated repo checks (gh-proxy.hackclub.com)
GH_PROXY_API_KEY=

# Inventory
INVENTORY_ALLOW_MULTIPLE_ORDERS=false
MIN_BITS_FOR_INVENTORY=0
VENUE_FLOORS=3
MAX_TEAM_SIZE=4
MAX_CONCURRENT_RENTALS=2
TOOL_RENTAL_TIME_LIMIT_MINUTES=0
DIGIKEY_CLIENT_ID=
DIGIKEY_CLIENT_SECRET=

# Blueprint integration (cross-platform project import)
BLUEPRINT_API_URL=https://blueprint.hackclub.com
BLUEPRINT_API_KEY=
